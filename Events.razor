@page "/events"
@using EventEase.Models

<h1>Events List 📅</h1>

<p>Browse all available events below:</p>

@foreach (var ev in events)
{
    <div style="border:1px solid #ddd; padding:15px; margin:10px 0; border-radius:8px;">
        <h3>@ev.Name</h3>

        <p><b>Date:</b> @ev.Date</p>
        <p><b>Location:</b> @ev.Location</p>

        <a href="/details/@ev.Id">👉 View Details</a>
    </div>
}

@code {
    List<Event> events = new()
    {
        new Event { Id = 1, Name = "Tech Conference", Date = "2026-07-01", Location = "Tunis" },
        new Event { Id = 2, Name = "Startup Meetup", Date = "2026-07-10", Location = "Sousse" },
        new Event { Id = 3, Name = "AI Workshop", Date = "2026-07-20", Location = "Sfax" }
    };
}
